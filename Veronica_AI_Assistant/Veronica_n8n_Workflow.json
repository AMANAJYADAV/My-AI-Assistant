      "parameters": {
        "toolDescription": "Use this tool to physically control the computer desktop, applications, and windows. You MUST provide two lowercase arguments: 'action' and 'payload'. To open any software, app, or browser (e.g., Chrome, Mathematica, Notepad), set action=\"open\" and payload=\"app_name\" (e.g., action=\"open\", payload=\"chrome\"). Do not invent actions like \"Open_Application\" or \"Open_Browser\". Use exactly what the script accepts.",
        "command": "==\"C:\\Users\\aman0\\anaconda_distribution\\python.exe\" \"D:\\veronica-core\\veronica_hands.py\" {{ $fromAI('action', 'The physical action to execute on screen', 'string') }} \"{{ $fromAI('payload', 'The text or coordinates needed for the action', 'string') }}\" ALLOWED"
